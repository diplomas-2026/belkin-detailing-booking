digraph database_schema {
  graph [rankdir=LR, splines=ortho, overlap=false, fontsize=18];
  node [shape=plain, fontname="Arial"];
  edge [fontname="Arial", fontsize=10];
  label="belkin-detailing-booking — full database schema";
  labelloc=t;

  "ai_feedback_summaries" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_feedback_summaries</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">target_type</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">summary</TD><TD ALIGN="LEFT">character varying(2000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">based_on_review_created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "ai_master_feedback" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_master_feedback</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">master_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → masters.id</TD></TR><TR><TD ALIGN="LEFT">summary</TD><TD ALIGN="LEFT">character varying(2000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">based_on_review_created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "ai_token_usage" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_token_usage</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">usage_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">used_tokens</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "ai_workshop_feedback" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>ai_workshop_feedback</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">summary</TD><TD ALIGN="LEFT">character varying(2000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">based_on_review_created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "appointment_service_items" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>appointment_service_items</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">appointment_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → appointments.id</TD></TR><TR><TD ALIGN="LEFT">service_item_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → service_items.id</TD></TR></TABLE>>];
  "appointment_services" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>appointment_services</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">appointment_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → appointments.id</TD></TR><TR><TD ALIGN="LEFT">service_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, FK → services.id</TD></TR></TABLE>>];
  "appointment_status_history" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>appointment_status_history</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;appointment_status_history_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">appointment_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → appointments.id</TD></TR><TR><TD ALIGN="LEFT">from_status</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">to_status</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">changed_by</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">changed_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">comment</TD><TD ALIGN="LEFT">character varying(300)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "appointments" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>appointments</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;appointments_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">client_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">car_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → cars.id</TD></TR><TR><TD ALIGN="LEFT">service_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → services.id</TD></TR><TR><TD ALIGN="LEFT">master_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → masters.id</TD></TR><TR><TD ALIGN="LEFT">scheduled_start</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">scheduled_end</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">total_price</TD><TD ALIGN="LEFT">numeric(12,2)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">client_comment</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">result_comment</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">cancelled_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">cancel_reason</TD><TD ALIGN="LEFT">character varying(300)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">payment_method</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">payment_status</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT &#x27;UNPAID&#x27;::character varying</TD></TR><TR><TD ALIGN="LEFT">paid_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "cars" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>cars</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;cars_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">client_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">brand</TD><TD ALIGN="LEFT">character varying(80)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">model</TD><TD ALIGN="LEFT">character varying(80)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">car_year</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">plate_number</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">color</TD><TD ALIGN="LEFT">character varying(50)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">notes</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "flyway_schema_history" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>flyway_schema_history</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">installed_rank</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">PK, NOT NULL</TD></TR><TR><TD ALIGN="LEFT">version</TD><TD ALIGN="LEFT">character varying(50)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">character varying(200)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">type</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">script</TD><TD ALIGN="LEFT">character varying(1000)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">checksum</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">installed_by</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">installed_on</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">execution_time</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">success</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "master_shifts" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>master_shifts</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;master_shifts_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">master_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → masters.id</TD></TR><TR><TD ALIGN="LEFT">shift_date</TD><TD ALIGN="LEFT">date</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">start_time</TD><TD ALIGN="LEFT">time without time zone</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">end_time</TD><TD ALIGN="LEFT">time without time zone</TD><TD ALIGN="LEFT">NOT NULL</TD></TR></TABLE>>];
  "masters" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>masters</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;masters_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">user_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">specialization</TD><TD ALIGN="LEFT">character varying(200)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">experience_years</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">photo_url</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "reviews" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>reviews</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;reviews_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">client_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → users.id</TD></TR><TR><TD ALIGN="LEFT">appointment_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → appointments.id</TD></TR><TR><TD ALIGN="LEFT">target_type</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">service_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → services.id</TD></TR><TR><TD ALIGN="LEFT">master_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → masters.id</TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">rating</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">comment</TD><TD ALIGN="LEFT">character varying(700)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">is_visible</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">moderation_status</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT &#x27;PENDING&#x27;::character varying</TD></TR><TR><TD ALIGN="LEFT">rejection_reason</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">ai_moderated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT"></TD></TR></TABLE>>];
  "service_items" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>service_items</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;service_items_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">service_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → services.id</TD></TR><TR><TD ALIGN="LEFT">kind</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">price</TD><TD ALIGN="LEFT">numeric(12,2)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">choice_group_key</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">default_selected</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT false</TD></TR><TR><TD ALIGN="LEFT">sort_order</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "services" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>services</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;services_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE, FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">duration_minutes</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">price</TD><TD ALIGN="LEFT">numeric(12,2)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR></TABLE>>];
  "users" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>users</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;users_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">full_name</TD><TD ALIGN="LEFT">character varying(150)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">character varying(150)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">password_hash</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">role</TD><TD ALIGN="LEFT">character varying(20)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
  "workshop_photos" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>workshop_photos</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;workshop_photos_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">workshop_id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">NOT NULL, FK → workshops.id</TD></TR><TR><TD ALIGN="LEFT">photo_url</TD><TD ALIGN="LEFT">character varying(500)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">sort_order</TD><TD ALIGN="LEFT">integer(32,0)</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT 0</TD></TR><TR><TD ALIGN="LEFT">is_cover</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT false</TD></TR></TABLE>>];
  "workshops" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>workshops</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;workshops_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(150)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">address</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">city</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">latitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">longitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">working_hours</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];

  "ai_master_feedback" -> "masters" [label="master_id → id"];
  "ai_workshop_feedback" -> "workshops" [label="workshop_id → id"];
  "appointment_service_items" -> "appointments" [label="appointment_id → id"];
  "appointment_service_items" -> "service_items" [label="service_item_id → id"];
  "appointment_services" -> "appointments" [label="appointment_id → id"];
