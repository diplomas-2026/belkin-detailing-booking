digraph single_table {
  graph [rankdir=TB, fontsize=18];
  node [shape=plain, fontname="Arial"];
  label="belkin-detailing-booking — workshops";
  labelloc=t;
  "workshops" [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6"><TR><TD BGCOLOR="#eeeeee" COLSPAN="3"><B>workshops</B></TD></TR><TR><TD><B>Поле</B></TD><TD><B>Тип</B></TD><TD><B>Модификаторы</B></TD></TR><TR><TD ALIGN="LEFT">id</TD><TD ALIGN="LEFT">bigint(64,0)</TD><TD ALIGN="LEFT">PK, NOT NULL, DEFAULT nextval(&#x27;workshops_id_seq&#x27;::regclass)</TD></TR><TR><TD ALIGN="LEFT">name</TD><TD ALIGN="LEFT">character varying(150)</TD><TD ALIGN="LEFT">NOT NULL, UNIQUE</TD></TR><TR><TD ALIGN="LEFT">description</TD><TD ALIGN="LEFT">text</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">address</TD><TD ALIGN="LEFT">character varying(255)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">city</TD><TD ALIGN="LEFT">character varying(100)</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">latitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">longitude</TD><TD ALIGN="LEFT">double precision</TD><TD ALIGN="LEFT">NOT NULL</TD></TR><TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">character varying(30)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">working_hours</TD><TD ALIGN="LEFT">character varying(120)</TD><TD ALIGN="LEFT"></TD></TR><TR><TD ALIGN="LEFT">is_active</TD><TD ALIGN="LEFT">boolean</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT true</TD></TR><TR><TD ALIGN="LEFT">created_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR><TR><TD ALIGN="LEFT">updated_at</TD><TD ALIGN="LEFT">timestamp without time zone</TD><TD ALIGN="LEFT">NOT NULL, DEFAULT now()</TD></TR></TABLE>>];
}